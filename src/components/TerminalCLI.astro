---
---
<div
	class="w-full max-w-[760px] mx-auto rounded-xl overflow-hidden shadow-xl border border-gray-200 dark:border-[#313244]"
>
	<div
		class="bg-[#2a2a3b] px-4 py-3 flex items-center relative border-b border-[#1e1e2e]"
	>
		<div class="flex space-x-2 absolute left-4">
			<div class="w-3 h-3 bg-[#ff5f56] rounded-full border border-[#e0443e]"></div>
			<div class="w-3 h-3 bg-[#ffbd2e] rounded-full border border-[#dea123]"></div>
			<div class="w-3 h-3 bg-[#27c93f] rounded-full border border-[#1aab29]"></div>
		</div>
		<div class="flex-1 text-center text-gray-400 text-xs font-semibold tracking-wide">
			yiming — bash
		</div>
	</div>
	<div
		id="terminal-body"
		class="bg-[#1e1e2e] p-4 min-h-[300px] max-h-[400px] overflow-y-auto text-sm text-gray-300 font-mono cursor-text"
	>
		<div id="terminal-output">
			<div class="text-gray-400 mb-4">
				Welcome to yiming's environment. Type 'help' to see available commands.
			</div>
		</div>
		<div class="flex items-center space-x-2 text-gray-300 mt-2">
			<span class="text-[#4ade80] font-semibold whitespace-nowrap">yiming@portfolio:~$</span>
			<div class="relative flex-1 flex items-center">
				<span
					id="input-mirror"
					class="absolute left-0 pointer-events-none text-white whitespace-pre"></span>
				<span
					id="cursor"
					class="absolute pointer-events-none inline-block w-[8px] h-[15px] bg-gray-400 animate-pulse align-middle"
					style="left:1px"></span>
				<input
					id="terminal-input"
					type="text"
					class="bg-transparent border-none outline-none flex-1 text-transparent caret-transparent w-full"
					autocomplete="off"
					spellcheck="false"
					autofocus
				/>
			</div>
		</div>
	</div>
</div>

<script>
const input = document.getElementById('terminal-input') as HTMLInputElement;
const output = document.getElementById('terminal-output')!;
const body = document.getElementById('terminal-body')!;
const mirror = document.getElementById('input-mirror') as HTMLElement;
const cursor = document.getElementById('cursor') as HTMLElement;

const updateCursor = () => {
	cursor.style.left = `${mirror.offsetWidth + 1}px`;
};

input.addEventListener('input', () => {
	mirror.textContent = input.value;
	updateCursor();
});

body.addEventListener('click', () => input.focus());

const commands: Record<string, string> = {
	help: `about   - View my background
skills  - List technical stack
contact - Display contact info
clear   - Clear terminal output`,
	about:
		'Senior Data Engineer with a PhD in Machine Learning and 8+ years building '
		+ 'DataOps/MLOps platforms. Currently at Wētā FX. Apache Airflow contributor.',
	skills:
		'Python · SQL · Apache Airflow · ClickHouse · Kubernetes · Kubeflow · '
		+ 'Great Expectations · dbt · AWS · Ansible · Terraform',
	contact:
		'Email: yimingpengjojo@gmail.com\n'
		+ 'GitHub: github.com/yimingpeng\n'
		+ 'LinkedIn: linkedin.com/in/yimingpeng'
};

function appendLine(cmd: string, result: string) {
	const cmdLine = document.createElement('div');
	cmdLine.className = 'flex items-start space-x-2 text-gray-300 break-all mb-1';
	const prompt = document.createElement('span');
	prompt.className = 'text-[#4ade80] font-semibold whitespace-nowrap';
	prompt.textContent = 'yiming@portfolio:~$';
	const cmdSpan = document.createElement('span');
	cmdSpan.className = 'text-white ml-2';
	cmdSpan.textContent = cmd;
	cmdLine.appendChild(prompt);
	cmdLine.appendChild(cmdSpan);
	output.appendChild(cmdLine);

	if (result) {
		const resultEl = document.createElement('div');
		resultEl.className = 'text-gray-300 mt-1 mb-3 whitespace-pre-wrap';
		resultEl.textContent = result;
		output.appendChild(resultEl);
	}
	body.scrollTop = body.scrollHeight;
}

input.addEventListener('keydown', (e) => {
	if (e.key !== 'Enter') return;
	const raw = input.value;
	const cmd = raw.trim().toLowerCase();
	input.value = '';
	mirror.textContent = '';
	updateCursor();

	if (cmd === '') return;

	if (cmd === 'clear') {
		output.innerHTML = '';
		return;
	}

	const result = commands[cmd] ?? `bash: ${cmd}: command not found`;
	appendLine(raw, result);
});
</script>
