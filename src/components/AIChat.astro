---
const chatApiUrl = import.meta.env.PUBLIC_AI_CHAT_API_URL ?? '';
---

<button
	id="chat-btn"
	class:list={[
		'group fixed bottom-6 right-6 z-40 flex items-center gap-2.5 rounded-full px-5 py-3',
		'bg-gradient-to-r from-[#2563eb] to-[#7c3aed] text-white shadow-lg shadow-blue-500/25',
		'transition-all hover:-translate-y-0.5 hover:shadow-xl hover:shadow-violet-500/30',
		'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#7c3aed] focus-visible:ring-offset-2',
		'dark:from-[#89b4fa] dark:to-[#cba6f7] dark:text-[#1e1e2e]'
	]}
	aria-label="Open AI Chat"
>
	<span
		class="grid h-7 w-7 place-items-center rounded-full bg-white/20 text-base transition-transform group-hover:rotate-6"
		aria-hidden="true">✦</span
	>
	<span class="text-sm font-bold tracking-tight">Ask Yiming</span>
	<span class="absolute -right-0.5 -top-0.5 h-3 w-3 rounded-full border-2 border-white bg-[#22c55e]"
	></span>
</button>

<div
	id="chat-modal"
	class:list={[
		'fixed inset-0 z-50 hidden items-end justify-center p-0 backdrop-blur-sm',
		'bg-gray-900/20 sm:items-center sm:p-4 dark:bg-black/50'
	]}
>
	<section
		class:list={[
			'relative flex h-[min(700px,100dvh)] w-full flex-col overflow-hidden',
			'rounded-t-3xl border border-[#e5e7eb] bg-white shadow-2xl',
			'sm:max-w-[440px] sm:rounded-3xl dark:border-[#45475a] dark:bg-[#1e1e2e]'
		]}
		aria-label="Ask Yiming assistant"
	>
		<div class="h-1 shrink-0 bg-gradient-to-r from-[#2563eb] via-[#8b5cf6] to-[#ec4899]"></div>
		<header
			class:list={[
				'flex items-center justify-between gap-4 border-b px-5 py-4',
				'border-[#e5e7eb] bg-gradient-to-br from-blue-50/80 to-violet-50/80',
				'dark:border-[#313244] dark:from-[#181825] dark:to-[#24243a]'
			]}
		>
			<div class="flex min-w-0 items-center gap-3">
				<div
					class="relative grid h-11 w-11 shrink-0 place-items-center rounded-2xl bg-gradient-to-br from-[#2563eb] to-[#8b5cf6] text-xl text-white shadow-md shadow-blue-500/20"
					aria-hidden="true"
				>
					✦
					<span
						class="absolute -bottom-0.5 -right-0.5 h-3.5 w-3.5 rounded-full border-2 border-white bg-[#22c55e] dark:border-[#24243a]"
					></span>
				</div>
				<div class="min-w-0">
					<h3 class="truncate text-base font-bold text-gray-900 dark:text-[#cdd6f4]">
						Yiming's AI sidekick
					</h3>
					<p class="mt-0.5 text-xs text-gray-500 dark:text-[#a6adc8]">
						Online · powered by portfolio facts
					</p>
				</div>
			</div>
			<button
				id="chat-close"
				class:list={[
					'grid h-9 w-9 shrink-0 place-items-center rounded-full text-gray-400',
					'transition-colors hover:bg-gray-100 hover:text-gray-900',
					'dark:hover:bg-[#313244] dark:hover:text-[#cdd6f4]'
				]}
				aria-label="Close chat"
			>
				<svg
					xmlns="http://www.w3.org/2000/svg"
					width="20"
					height="20"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true"
				>
					<path d="M18 6 6 18M6 6l12 12"></path>
				</svg>
			</button>
		</header>

		<div
			id="chat-messages"
			class="flex-1 space-y-4 overflow-y-auto bg-gradient-to-b from-white to-gray-50/70 px-5 py-5 text-sm dark:from-[#1e1e2e] dark:to-[#181825]"
			aria-live="polite"
		>
			<div class="flex items-end gap-2.5">
				<div
					class="grid h-7 w-7 shrink-0 place-items-center rounded-xl bg-gradient-to-br from-[#2563eb] to-[#8b5cf6] text-xs text-white"
					aria-hidden="true"
				>
					✦
				</div>
				<div
					class="max-w-[88%] rounded-2xl rounded-bl-md border border-gray-200 bg-white px-4 py-3 leading-relaxed text-gray-700 shadow-sm dark:border-[#313244] dark:bg-[#11111b] dark:text-[#bac2de]"
				>
					Hey! 👋 I know the highlights of Yiming's work, research, and community adventures. What
					would you like to explore?
				</div>
			</div>
			<div id="chat-suggestions" class="flex flex-wrap gap-2 pl-9">
				<button
					type="button"
					data-prompt="What kind of systems does Yiming build?"
					class="rounded-full border border-blue-200 bg-blue-50 px-3 py-1.5 text-xs font-medium text-blue-700 transition hover:-translate-y-0.5 hover:bg-blue-100 dark:border-[#89b4fa]/30 dark:bg-[#89b4fa]/10 dark:text-[#89b4fa]"
					>🛠️ What does he build?</button
				>
				<button
					type="button"
					data-prompt="Tell me about Yiming's research and publications."
					class="rounded-full border border-violet-200 bg-violet-50 px-3 py-1.5 text-xs font-medium text-violet-700 transition hover:-translate-y-0.5 hover:bg-violet-100 dark:border-[#cba6f7]/30 dark:bg-[#cba6f7]/10 dark:text-[#cba6f7]"
					>📚 Research</button
				>
				<button
					type="button"
					data-prompt="How is Yiming involved in the tech community?"
					class="rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1.5 text-xs font-medium text-emerald-700 transition hover:-translate-y-0.5 hover:bg-emerald-100 dark:border-[#a6e3a1]/30 dark:bg-[#a6e3a1]/10 dark:text-[#a6e3a1]"
					>🌱 Community</button
				>
			</div>
		</div>

		<div
			id="chat-error"
			class:list={[
				'mx-5 mb-3 hidden rounded-lg border px-3 py-2 text-xs',
				'border-amber-200 bg-amber-50 text-amber-800',
				'dark:border-[#f9e2af]/40 dark:bg-[#f9e2af]/10 dark:text-[#f9e2af]'
			]}
		>
		</div>

		<form
			id="chat-form"
			class="border-t border-[#e5e7eb] bg-white p-4 dark:border-[#313244] dark:bg-[#181825]"
			autocomplete="off"
		>
			<label for="chat-input" class="sr-only">Ask a question</label>
			<div
				class="flex items-end gap-2 rounded-2xl border border-[#d1d5db] bg-white p-1.5 shadow-sm transition focus-within:border-[#2563eb] focus-within:ring-2 focus-within:ring-[#2563eb]/15 dark:border-[#45475a] dark:bg-[#11111b] dark:focus-within:border-[#89b4fa] dark:focus-within:ring-[#89b4fa]/15"
			>
				<textarea
					id="chat-input"
					name="message"
					rows="1"
					maxlength="1500"
					placeholder="Ask about Yiming's work..."
					class:list={[
						'max-h-28 min-h-10 flex-1 resize-none border-0 bg-transparent px-2 py-2',
						'text-sm leading-6 text-gray-900 outline-none dark:text-[#cdd6f4]',
						'dark:placeholder:text-[#6c7086]'
					]}></textarea>
				<button
					id="chat-send"
					type="submit"
					class:list={[
						'grid h-10 w-10 shrink-0 place-items-center rounded-xl',
						'bg-gradient-to-br from-[#2563eb] to-[#7c3aed] text-white shadow-sm transition',
						'hover:scale-105 disabled:cursor-not-allowed disabled:opacity-60',
						'dark:from-[#89b4fa] dark:to-[#cba6f7] dark:text-[#1e1e2e]'
					]}
					aria-label="Send message"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="18"
						height="18"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						aria-hidden="true"
					>
						<path d="m22 2-7 20-4-9-9-4Z"></path>
						<path d="M22 2 11 13"></path>
					</svg>
				</button>
			</div>
			<div
				class="mt-2 flex flex-wrap items-center justify-between gap-x-3 gap-y-1 px-1 text-[11px]"
			>
				<p class="text-gray-400 dark:text-[#6c7086]">Limit: 10 questions per day</p>
				<p class="text-gray-500 dark:text-[#a6adc8]">
					<kbd
						class="rounded border border-gray-200 bg-gray-50 px-1.5 py-0.5 font-sans dark:border-[#45475a] dark:bg-[#313244]"
						>Enter</kbd
					>
					<span> send</span>
					<span class="px-1 text-gray-300 dark:text-[#45475a]">·</span>
					<kbd
						class="rounded border border-gray-200 bg-gray-50 px-1.5 py-0.5 font-sans dark:border-[#45475a] dark:bg-[#313244]"
						>Shift + Enter</kbd
					>
					<span> new line</span>
				</p>
			</div>
		</form>
	</section>
</div>

<script define:vars={{ chatApiUrl }}>
	const btn = document.getElementById('chat-btn');
	const modal = document.getElementById('chat-modal');
	const close = document.getElementById('chat-close');
	const form = document.getElementById('chat-form');
	const input = document.getElementById('chat-input');
	const messagesEl = document.getElementById('chat-messages');
	const errorEl = document.getElementById('chat-error');
	const sendBtn = document.getElementById('chat-send');
	const suggestions = document.getElementById('chat-suggestions');
	const fallbackApiUrl =
		window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1'
			? 'http://localhost:8787/chat'
			: '';
	const apiUrl = chatApiUrl || fallbackApiUrl;
	const history = [];

	function openChat() {
		modal.classList.remove('hidden');
		modal.classList.add('flex');
		input.focus();
	}

	function closeChat() {
		modal.classList.add('hidden');
		modal.classList.remove('flex');
	}

	function setError(message) {
		if (!message) {
			errorEl.textContent = '';
			errorEl.classList.add('hidden');
			return;
		}

		errorEl.textContent = message;
		errorEl.classList.remove('hidden');
	}

	function appendMessage(role, content) {
		const row = document.createElement('div');
		const item = document.createElement('div');
		const userClasses = [
			'ml-auto max-w-[85%] whitespace-pre-wrap rounded-2xl rounded-br-md',
			'bg-gradient-to-br from-[#2563eb] to-[#7c3aed] px-4 py-3 leading-relaxed text-white',
			'shadow-sm dark:from-[#89b4fa] dark:to-[#cba6f7] dark:text-[#1e1e2e]'
		];
		const assistantClasses = [
			'max-w-[88%] whitespace-pre-wrap rounded-2xl rounded-bl-md border border-gray-200',
			'bg-white px-4 py-3 leading-relaxed text-gray-700 shadow-sm',
			'dark:border-[#313244] dark:bg-[#11111b] dark:text-[#bac2de]'
		];
		item.className = role === 'user' ? userClasses.join(' ') : assistantClasses.join(' ');
		item.textContent = content;
		if (role === 'assistant') {
			const avatar = document.createElement('div');
			avatar.className = [
				'grid h-7 w-7 shrink-0 place-items-center rounded-xl',
				'bg-gradient-to-br from-[#2563eb] to-[#8b5cf6] text-xs text-white'
			].join(' ');
			avatar.textContent = '✦';
			avatar.setAttribute('aria-hidden', 'true');
			row.className = 'flex items-end gap-2.5';
			row.append(avatar, item);
		} else {
			row.className = 'flex justify-end';
			row.appendChild(item);
		}
		messagesEl.appendChild(row);
		messagesEl.scrollTop = messagesEl.scrollHeight;
	}

	function resizeInput() {
		input.style.height = 'auto';
		input.style.height = `${Math.min(input.scrollHeight, 112)}px`;
	}

	function setLoading(isLoading) {
		sendBtn.disabled = isLoading;
		input.disabled = isLoading;
		sendBtn.setAttribute('aria-busy', String(isLoading));
	}

	async function sendMessage(message) {
		let response;
		try {
			response = await fetch(apiUrl, {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({
					message,
					history: history.slice(-12)
				})
			});
		} catch {
			throw new Error('The assistant API is not reachable. Start the Worker or try again later.');
		}

		const payload = await response.json();

		if (!response.ok) {
			throw new Error(payload.error || 'The assistant could not answer right now.');
		}

		if (!payload.answer) {
			throw new Error('The assistant returned an empty answer.');
		}

		return payload.answer;
	}

	btn.addEventListener('click', openChat);
	close.addEventListener('click', closeChat);
	document.addEventListener('keydown', event => {
		if (event.key === 'Escape' && !modal.classList.contains('hidden')) closeChat();
	});
	modal.addEventListener('click', event => {
		if (event.target === modal) closeChat();
	});
	input.addEventListener('input', resizeInput);
	input.addEventListener('keydown', event => {
		if (event.key !== 'Enter' || event.shiftKey || event.isComposing) return;

		event.preventDefault();
		if (!sendBtn.disabled) form.requestSubmit();
	});
	suggestions.addEventListener('click', event => {
		const target = event.target.closest('[data-prompt]');
		if (!(target instanceof HTMLButtonElement)) return;

		input.value = target.dataset.prompt || '';
		resizeInput();
		input.focus();
	});
	form.addEventListener('submit', async event => {
		event.preventDefault();
		setError('');

		const message = input.value.trim();
		if (!message) return;
		if (!apiUrl) {
			setError('The assistant endpoint is not configured yet.');
			return;
		}

		input.value = '';
		resizeInput();
		suggestions.classList.add('hidden');
		appendMessage('user', message);
		history.push({ role: 'user', content: message });
		setLoading(true);

		try {
			const answer = await sendMessage(message);
			appendMessage('assistant', answer);
			history.push({ role: 'assistant', content: answer });
		} catch (error) {
			setError(error instanceof Error ? error.message : 'The assistant could not answer.');
		} finally {
			setLoading(false);
			input.focus();
		}
	});
</script>
