				<div class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline">
					<div class="flex items-baseline space-x-2">
						<span class="font-semibold text-gray-800 dark:text-[#cdd6f4]">IHC New Zealand</span>
						<span class="text-gray-400 dark:text-[#6c7086] hidden sm:inline">—</span>
						<span class="text-gray-600 dark:text-[#bac2de]">
