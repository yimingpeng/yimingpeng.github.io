---
// Writing / Blog placeholder section — future Obsidian integration
---

<section class="section" id="writing">
	<div class="container">
		<h2 class="section-title">$ ls ./writing</h2>
		<div class="writing-content">
			<p class="writing-note">
				<span class="prompt">$</span> Articles on data engineering, platform design, and lessons from
				production systems. Coming soon — will be published from Obsidian.
			</p>
			<div class="writing-links">
				<a
					href="https://medium.com/@yimingpeng"
					target="_blank"
					rel="noopener noreferrer"
					class="writing-link"
				>
					Medium →
				</a>
			</div>
		</div>
	</div>
</section>

<style>
	.section {
		padding: 4rem 0;
	}

	.container {
		max-width: 1000px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}

	.section-title {
		font-family: 'JetBrains Mono', 'Fira Code', monospace;
		font-size: 1.4rem;
		color: #a6e3a1;
		font-weight: 500;
		margin-bottom: 2rem;
	}

	.writing-content {
		border-left: 1px solid rgba(166, 227, 161, 0.2);
		padding-left: 1.5rem;
		margin-left: 0.5rem;
	}

	.writing-note {
		color: #6c7086;
		font-size: 0.95rem;
		line-height: 1.7;
		margin-bottom: 1.25rem;
	}

	.prompt {
		color: #a6e3a1;
		font-family: 'JetBrains Mono', 'Fira Code', monospace;
		margin-right: 0.5rem;
	}

	.writing-links {
		display: flex;
		gap: 1rem;
	}

	.writing-link {
		color: #89b4fa;
		font-family: 'JetBrains Mono', 'Fira Code', monospace;
		font-size: 0.9rem;
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.writing-link:hover {
		color: #a6e3a1;
	}
</style>
