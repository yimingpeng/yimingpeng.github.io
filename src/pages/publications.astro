---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import { getSortedPublications, SCHOLAR_URL, TOTAL_CITATIONS } from '../data/publications';

const publications = getSortedPublications();
const peerReviewedCount = publications.filter(publication =>
	['journal', 'conference'].includes(publication.type)
).length;
const years = publications.map(publication => publication.year);
const yearSpan = `${Math.min(...years)}-${Math.max(...years)}`;

const renderAuthors = (authors: string) =>
	authors.split(/(Y Peng)/g).map(part => ({
		text: part,
		isSelf: part === 'Y Peng'
	}));
---

<BaseLayout
	title="Publications - Yiming Peng"
	description="Research publications by Yiming Peng in reinforcement learning and evolutionary computation."
>
	<Header />
	<main class="pt-24 pb-20 max-w-[760px] mx-auto px-6">
		<section class="space-y-12">
			<div class="space-y-4">
				<div class="space-y-2">
					<h1 class="text-lg font-bold text-gray-900 dark:text-[#cdd6f4]">Publications</h1>
					<p class="text-sm text-gray-500 dark:text-[#6c7086]">
						{peerReviewedCount} peer-reviewed papers, {publications.length} publications total,
						{yearSpan}, {TOTAL_CITATIONS}+ citations.
					</p>
				</div>
				<div class="flex flex-wrap gap-4">
					<a href="/" class="text-sm text-blue-600 dark:text-[#89b4fa] hover:underline">
						← Back to home
					</a>
					<a
						href={SCHOLAR_URL}
						class="text-sm text-blue-600 dark:text-[#89b4fa] hover:underline"
						target="_blank"
						rel="noopener noreferrer"
					>
						Google Scholar →
					</a>
				</div>
			</div>

			<div class="space-y-10">
				{
					publications.map(publication => (
						<article class="space-y-2">
							<div class="flex items-baseline gap-3 flex-wrap">
								<span class="text-xs text-gray-400 dark:text-[#6c7086] font-mono">
									{publication.year}
								</span>
								<span class="text-xs uppercase tracking-widest text-gray-400 dark:text-[#6c7086]">
									{publication.type}
								</span>
							</div>
							<h2 class="text-base font-semibold text-gray-900 dark:text-[#cdd6f4] leading-snug">
								{publication.title}
							</h2>
							<p class="text-sm text-gray-700 dark:text-[#bac2de] leading-relaxed">
								{renderAuthors(publication.authors).map(part =>
									part.isSelf ? <strong class="font-semibold">{part.text}</strong> : part.text
								)}
							</p>
							<p class="text-sm text-gray-500 dark:text-[#6c7086]">{publication.venue}</p>
							<hr class="border-gray-100 dark:border-[#313244] pt-4" />
						</article>
					))
				}
			</div>
		</section>
	</main>
</BaseLayout>
