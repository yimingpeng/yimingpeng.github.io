---
// Compact experience timeline — role, company, date on one line each
---

<section class="section experience-section" id="experience">
	<div class="container">
		<h2 class="section-title">$ cat experience.log</h2>
		<div class="timeline">
			<div class="timeline-item">
				<span class="role">Senior Software Engineer — Data</span>
				<span class="company">Wētā FX</span>
				<span class="date">Oct 2023 – Present</span>
			</div>
			<div class="timeline-item">
				<span class="role">Data Architect</span>
				<span class="company">MBIE (via Emergence CLI)</span>
				<span class="date">Jul 2022 – Jul 2023</span>
			</div>
			<div class="timeline-item">
				<span class="role">Principal Data & Integration Architect</span>
				<span class="company">IHC New Zealand</span>
				<span class="date">Jul 2021 – Jul 2022</span>
			</div>
			<div class="timeline-item">
				<span class="role">Senior Data Engineer</span>
				<span class="company">Chorus New Zealand</span>
				<span class="date">Dec 2019 – Jun 2021</span>
			</div>
			<div class="timeline-item">
				<span class="role">Data Engineer</span>
				<span class="company">KPMG New Zealand</span>
				<span class="date">Mar 2019 – Nov 2019</span>
			</div>
			<div class="timeline-item">
				<span class="role">Research Scientist & Research Assistant</span>
				<span class="company">Victoria University of Wellington</span>
				<span class="date">Sep 2015 – Mar 2019</span>
			</div>
			<div class="timeline-item">
				<span class="role">Research & Teaching Assistant</span>
				<span class="company">Unitec Institute of Technology</span>
				<span class="date">Sep 2011 – Jun 2015</span>
			</div>
		</div>
		<div class="credentials">
			<h3 class="credentials-title">Certifications</h3>
			<div class="cert-item">
				<span class="cert-name">Certified Kubernetes Administrator (CKA)</span>
				<span class="cert-issuer">Linux Foundation</span>
				<span class="cert-year">2025</span>
				<a
					href="https://www.credly.com/badges/ec7232b8-b542-4daa-8846-07372b66fc03/linked_in_profile"
					target="_blank"
					rel="noopener noreferrer"
					class="cert-link"
					title="CKA Certificate"
				>
					<img
						src="/files/certifications/cka.png"
						alt="CKA badge"
						class="cert-badge-icon"
						loading="lazy"
						decoding="async"
					/>
					[view credential]
				</a>
			</div>
			<div class="cert-item">
				<span class="cert-name">Certified Kubernetes Application Developer (CKAD)</span>
				<span class="cert-issuer">Linux Foundation</span>
				<span class="cert-year">2025</span>
				<a
					href="https://www.credly.com/badges/bff106cd-060d-4185-8989-0eb2fac2d712/linked_in_profile"
					target="_blank"
					rel="noopener noreferrer"
					class="cert-link"
					title="CKAD Certificate"
				>
					<img
						src="/files/certifications/ckad.png"
						alt="CKAD badge"
						class="cert-badge-icon"
						loading="lazy"
						decoding="async"
					/>
					[view credential]
				</a>
			</div>
			<div class="cert-item">
				<span class="cert-name">Tableau Server Admin</span>
				<span class="cert-issuer">Tableau</span>
				<span class="cert-year">Certification</span>
				<a
					href="https://www.credly.com/badges/acd0bdd4-286a-436e-a60b-bfe2e853d618/linked_in_profile"
					target="_blank"
					rel="noopener noreferrer"
					class="cert-link"
					title="Tableau Server Admin Certificate"
				>
					<img
						src="/files/certifications/tableau-server-admin.png"
						alt="Tableau Server Admin badge"
						class="cert-badge-icon"
						loading="lazy"
						decoding="async"
					/>
					[view credential]
				</a>
			</div>
			<div class="cert-item">
				<span class="cert-name">Astronomer Certification DAG Authoring for Apache Airflow 2</span>
				<span class="cert-issuer">Astronomer</span>
				<span class="cert-year">Certification</span>
				<a
					href="https://www.credly.com/badges/a1d12623-df6c-445b-bcb7-51a767425001/linked_in_profile"
					target="_blank"
					rel="noopener noreferrer"
					class="cert-link"
					title="Astronomer Certification DAG Authoring for Apache Airflow 2"
				>
					<img
						src="/files/certifications/astronomer-dag-authoring-airflow2.png"
						alt="Astronomer DAG Authoring badge"
						class="cert-badge-icon"
						loading="lazy"
						decoding="async"
					/>
					[view credential]
				</a>
			</div>
			<div class="cert-item">
				<span class="cert-name">Astronomer Certification for Apache Airflow 2 Fundamentals</span>
				<span class="cert-issuer">Astronomer</span>
				<span class="cert-year">Certification</span>
				<a
					href="https://www.credly.com/badges/6030784e-da5e-4236-a2ae-e077cf82f7bd/linked_in_profile"
					target="_blank"
					rel="noopener noreferrer"
					class="cert-link"
					title="Astronomer Certification for Apache Airflow 2 Fundamentals"
				>
					<img
						src="/files/certifications/astronomer-airflow2-fundamentals.png"
						alt="Astronomer Airflow Fundamentals badge"
						class="cert-badge-icon"
						loading="lazy"
						decoding="async"
					/>
					[view credential]
				</a>
			</div>
		</div>
		<div class="cv-cta">
			<a href="/yiming_cv.pdf" target="_blank" rel="noopener noreferrer" class="cv-button">
				Full CV / Résumé
				<svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14">
					<path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"></path>
				</svg>
			</a>
		</div>
	</div>
</section>
