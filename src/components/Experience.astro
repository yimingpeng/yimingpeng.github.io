---
// Compact experience timeline — role, company, date on one line each
---

<section class="section" id="experience">
	<div class="container">
		<h2 class="section-title">$ cat experience.log</h2>
		<div class="timeline">
			<div class="timeline-item">
				<span class="role">Senior Software Engineer — Data</span>
				<span class="company">Wētā FX</span>
				<span class="date">Oct 2023 – Present</span>
			</div>
			<div class="timeline-item">
				<span class="role">Data Architect</span>
				<span class="company">MBIE (via Emergence CLI)</span>
				<span class="date">Jul 2022 – Jul 2023</span>
			</div>
			<div class="timeline-item">
				<span class="role">Principal Data & Integration Architect</span>
				<span class="company">IHC New Zealand</span>
				<span class="date">Jul 2021 – Jul 2022</span>
			</div>
			<div class="timeline-item">
				<span class="role">Senior Data Engineer</span>
				<span class="company">Chorus New Zealand</span>
				<span class="date">Dec 2019 – Jun 2021</span>
			</div>
			<div class="timeline-item">
				<span class="role">Data Engineer</span>
				<span class="company">KPMG New Zealand</span>
				<span class="date">Mar 2019 – Nov 2019</span>
			</div>
			<div class="timeline-item">
				<span class="role">Research Scientist & Research Assistant</span>
				<span class="company">Victoria University of Wellington</span>
				<span class="date">Sep 2015 – Mar 2019</span>
			</div>
			<div class="timeline-item">
				<span class="role">Research & Teaching Assistant</span>
				<span class="company">Unitec Institute of Technology</span>
				<span class="date">Sep 2011 – Jun 2015</span>
			</div>
		</div>
		<div class="credentials">
			<h3 class="credentials-title">Certifications</h3>
			<div class="cert-item">
				<span class="cert-name">Certified Kubernetes Administrator (CKA)</span>
				<span class="cert-issuer">Linux Foundation</span>
				<span class="cert-year">2025</span>
				<a href="#" class="cert-link" title="Add credential link">[link TBD]</a>
			</div>
			<div class="cert-item">
				<span class="cert-name">Certified Kubernetes Application Developer (CKAD)</span>
				<span class="cert-issuer">Linux Foundation</span>
				<span class="cert-year">2025</span>
				<a href="#" class="cert-link" title="Add credential link">[link TBD]</a>
			</div>
		</div>
		<div class="cv-cta">
			<a href="/yiming_cv.pdf" target="_blank" rel="noopener noreferrer" class="cv-button">
				Full CV / Résumé
				<svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14">
					<path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"></path>
				</svg>
			</a>
		</div>
	</div>
</section>

<style>
	.section {
		padding: 4rem 0;
	}

	.container {
		max-width: 1000px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}

	.section-title {
		font-family: 'JetBrains Mono', 'Fira Code', monospace;
		font-size: 1.4rem;
		color: #a6e3a1;
		font-weight: 500;
		margin-bottom: 2.5rem;
	}

	.timeline {
		max-width: 700px;
		display: flex;
		flex-direction: column;
		gap: 0;
		border-left: 1px solid rgba(166, 227, 161, 0.2);
		padding-left: 1.5rem;
		margin-left: 0.5rem;
	}

	.timeline-item {
		position: relative;
		padding: 0.9rem 0;
		border-bottom: 1px solid rgba(69, 71, 90, 0.4);
		display: grid;
		grid-template-columns: 1fr auto auto;
		align-items: center;
		gap: 1rem;
	}

	.timeline-item:last-child {
		border-bottom: none;
	}

	.timeline-item::before {
		content: '';
		position: absolute;
		left: -1.65rem;
		top: 50%;
		transform: translateY(-50%);
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: #a6e3a1;
	}

	.role {
		font-size: 0.95rem;
		color: #cdd6f4;
		font-weight: 500;
	}

	.company {
		font-size: 0.9rem;
		color: #89b4fa;
		font-family: 'JetBrains Mono', 'Fira Code', monospace;
		white-space: nowrap;
	}

	.date {
		font-size: 0.82rem;
		color: #6c7086;
		font-family: 'JetBrains Mono', 'Fira Code', monospace;
		white-space: nowrap;
	}

	.credentials {
		max-width: 700px;
		margin-top: 2.5rem;
		margin-left: 0.5rem;
	}

	.credentials-title {
		font-family: 'JetBrains Mono', 'Fira Code', monospace;
		font-size: 0.78rem;
		color: #6c7086;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin-bottom: 0.75rem;
	}

	.cert-item {
		display: grid;
		grid-template-columns: 1fr auto auto auto;
		align-items: center;
		gap: 1rem;
		padding: 0.6rem 0;
		border-bottom: 1px solid rgba(69, 71, 90, 0.3);
	}

	.cert-item:last-child {
		border-bottom: none;
	}

	.cert-name {
		font-size: 0.9rem;
		color: #cdd6f4;
		font-weight: 500;
	}

	.cert-issuer {
		font-size: 0.82rem;
		color: #89b4fa;
		font-family: 'JetBrains Mono', 'Fira Code', monospace;
		white-space: nowrap;
	}

	.cert-year {
		font-size: 0.82rem;
		color: #6c7086;
		font-family: 'JetBrains Mono', 'Fira Code', monospace;
		white-space: nowrap;
	}

	.cert-link {
		font-size: 0.78rem;
		color: #45475a;
		font-family: 'JetBrains Mono', 'Fira Code', monospace;
		text-decoration: none;
		font-style: italic;
		white-space: nowrap;
		transition: color 0.2s ease;
	}

	.cert-link:hover {
		color: #89b4fa;
	}

	.cv-cta {
		margin-top: 2rem;
		padding-left: 0.5rem;
	}

	.cv-button {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 1.25rem;
		border: 1px solid rgba(166, 227, 161, 0.35);
		border-radius: 6px;
		color: #a6e3a1;
		font-family: 'JetBrains Mono', 'Fira Code', monospace;
		font-size: 0.85rem;
		text-decoration: none;
		transition: all 0.2s ease;
	}

	.cv-button:hover {
		background: rgba(166, 227, 161, 0.08);
		border-color: #a6e3a1;
	}

	@media (max-width: 640px) {
		.timeline-item {
			grid-template-columns: 1fr;
			gap: 0.25rem;
		}

		.company,
		.date {
			font-size: 0.8rem;
		}

		.cert-item {
			grid-template-columns: 1fr auto;
			grid-template-rows: auto auto;
		}

		.cert-issuer {
			grid-column: 1;
		}

		.cert-year {
			grid-column: 2;
			grid-row: 1;
		}

		.cert-link {
			grid-column: 1 / -1;
		}
	}
</style>
