---

<BaseLayout
	title="Project Archive — Yiming Peng"
	description="Full archive of projects by Yiming Peng across data engineering, MLOps, and research."
>
	<Header />
	<main class="archive-page">
		<div class="container">
			<div class="page-header">
				<a href="/#projects" class="back-link">← Back</a>
				<h1 class="page-title">$ ls -la ./all-projects</h1>
				<p class="page-subtitle">All noteworthy projects, ordered by recency.</p>
			</div>

			<div class="table-wrapper">
				<table class="projects-table">
					<thead>
						<tr>
							<th class="col-year">Year</th>
							<th class="col-project">Project</th>
							<th class="col-madeat">Made at</th>
							<th class="col-tech">Built with</th>
						</tr>
					</thead>
					<tbody>
						{
							projects.map(p => (
								<tr id={toAnchorId(p.name)}>
									<td class="year">{p.year}</td>
									<td class="project-cell">
										<span class="project-name">{p.name}</span>
										<span class="project-desc">{p.description}</span>
									</td>
									<td class="made-at">{p.madeAt}</td>
									<td class="tech-list">
										{p.tech.map((t, i) => (
											<span>
												{t}
												{i < p.tech.length - 1 && <span class="tech-sep"> · </span>}
											</span>
										))}
									</td>
								</tr>
							))
						}
					</tbody>
				</table>
			</div>
		</div>
	</main>
</BaseLayout>
