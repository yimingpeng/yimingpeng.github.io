---
const chatApiUrl = import.meta.env.PUBLIC_AI_CHAT_API_URL ?? '';
---

<button
	id="chat-btn"
	class:list={[
		'fixed bottom-6 right-6 z-40 flex items-center gap-2 rounded-full px-5 py-3',
		'bg-[#2563eb] text-white shadow-lg transition-transform hover:scale-105',
		'dark:bg-[#89b4fa] dark:text-[#1e1e2e]'
	]}
	aria-label="Open AI Chat"
>
	<svg
		xmlns="http://www.w3.org/2000/svg"
		width="18"
		height="18"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
		aria-hidden="true"
	>
		<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
	</svg>
	<span class="text-sm font-bold tracking-tight">Ask Yiming</span>
</button>

<div
	id="chat-modal"
	class:list={[
		'fixed inset-0 z-50 hidden items-end justify-center p-0 backdrop-blur-sm',
		'bg-gray-900/20 sm:items-center sm:p-4 dark:bg-black/50'
	]}
>
	<section
		class:list={[
			'relative flex h-[min(680px,100dvh)] w-full flex-col overflow-hidden',
			'rounded-t-xl border border-[#e5e7eb] bg-white shadow-2xl',
			'sm:max-w-[420px] sm:rounded-xl dark:border-[#313244] dark:bg-[#1e1e2e]'
		]}
		aria-label="Ask Yiming assistant"
	>
		<header
			class:list={[
				'flex items-start justify-between gap-4 border-b px-5 py-4',
				'border-[#e5e7eb] dark:border-[#313244]'
			]}
		>
			<div class="min-w-0">
				<h3 class="text-base font-bold text-gray-900 dark:text-[#cdd6f4]">Ask Yiming</h3>
				<p class="mt-1 text-xs leading-relaxed text-gray-500 dark:text-[#a6adc8]">
					Answers use public portfolio content. For private or current availability questions, email
					Yiming.
				</p>
			</div>
			<button
				id="chat-close"
				class:list={[
					'grid h-9 w-9 shrink-0 place-items-center rounded-full text-gray-400',
					'transition-colors hover:bg-gray-100 hover:text-gray-900',
					'dark:hover:bg-[#313244] dark:hover:text-[#cdd6f4]'
				]}
				aria-label="Close chat"
			>
				<svg
					xmlns="http://www.w3.org/2000/svg"
					width="20"
					height="20"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true"
				>
					<path d="M18 6 6 18M6 6l12 12"></path>
				</svg>
			</button>
		</header>

		<div
			id="chat-messages"
			class="flex-1 space-y-3 overflow-y-auto px-5 py-4 text-sm"
			aria-live="polite"
		>
			<div class="rounded-lg bg-gray-100 p-3 text-gray-700 dark:bg-[#11111b] dark:text-[#bac2de]">
				Hi, I can answer questions about Yiming's experience, publications, projects, and community
				work.
			</div>
		</div>

		<div
			id="chat-error"
			class:list={[
				'mx-5 mb-3 hidden rounded-lg border px-3 py-2 text-xs',
				'border-amber-200 bg-amber-50 text-amber-800',
				'dark:border-[#f9e2af]/40 dark:bg-[#f9e2af]/10 dark:text-[#f9e2af]'
			]}
		>
		</div>

		<form
			id="chat-form"
			class="border-t border-[#e5e7eb] p-4 dark:border-[#313244]"
			autocomplete="off"
		>
			<label for="chat-input" class="sr-only">Ask a question</label>
			<div class="flex items-end gap-2">
				<textarea
					id="chat-input"
					name="message"
					rows="2"
					maxlength="1500"
					placeholder="Ask about Yiming's work..."
					class:list={[
						'max-h-28 min-h-11 flex-1 resize-none rounded-lg border px-3 py-2',
						'border-[#d1d5db] bg-white text-sm text-gray-900 outline-none transition',
						'focus:border-[#2563eb] focus:ring-2 focus:ring-[#2563eb]/20',
						'dark:border-[#45475a] dark:bg-[#11111b] dark:text-[#cdd6f4]',
						'dark:placeholder:text-[#6c7086] dark:focus:border-[#89b4fa]',
						'dark:focus:ring-[#89b4fa]/20'
					]}></textarea>
				<button
					id="chat-send"
					type="submit"
					class:list={[
						'grid h-11 w-11 shrink-0 place-items-center rounded-lg bg-[#2563eb]',
						'text-white transition hover:bg-[#1d4ed8] disabled:cursor-not-allowed',
						'disabled:opacity-60 dark:bg-[#89b4fa] dark:text-[#1e1e2e]'
					]}
					aria-label="Send message"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="18"
						height="18"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						aria-hidden="true"
					>
						<path d="m22 2-7 20-4-9-9-4Z"></path>
						<path d="M22 2 11 13"></path>
					</svg>
				</button>
			</div>
			<p class="mt-2 text-[11px] text-gray-400 dark:text-[#6c7086]">
				Limit: 10 questions per day per visitor.
			</p>
		</form>
	</section>
</div>

<script define:vars={{ chatApiUrl }}>
	const btn = document.getElementById('chat-btn');
	const modal = document.getElementById('chat-modal');
	const close = document.getElementById('chat-close');
	const form = document.getElementById('chat-form');
	const input = document.getElementById('chat-input');
	const messagesEl = document.getElementById('chat-messages');
	const errorEl = document.getElementById('chat-error');
	const sendBtn = document.getElementById('chat-send');
	const fallbackApiUrl =
		window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1'
			? 'http://localhost:8787/chat'
			: '';
	const apiUrl = chatApiUrl || fallbackApiUrl;
	const history = [];

	function openChat() {
		modal.classList.remove('hidden');
		modal.classList.add('flex');
		input.focus();
	}

	function closeChat() {
		modal.classList.add('hidden');
		modal.classList.remove('flex');
	}

	function setError(message) {
		if (!message) {
			errorEl.textContent = '';
			errorEl.classList.add('hidden');
			return;
		}

		errorEl.textContent = message;
		errorEl.classList.remove('hidden');
	}

	function appendMessage(role, content) {
		const item = document.createElement('div');
		const userClasses = [
			'ml-auto max-w-[85%] rounded-lg bg-[#2563eb] p-3 text-white',
			'dark:bg-[#89b4fa] dark:text-[#1e1e2e]'
		];
		const assistantClasses = [
			'max-w-[88%] rounded-lg bg-gray-100 p-3 text-gray-700',
			'dark:bg-[#11111b] dark:text-[#bac2de]'
		];
		item.className = role === 'user' ? userClasses.join(' ') : assistantClasses.join(' ');
		item.textContent = content;
		messagesEl.appendChild(item);
		messagesEl.scrollTop = messagesEl.scrollHeight;
	}

	function setLoading(isLoading) {
		sendBtn.disabled = isLoading;
		input.disabled = isLoading;
		sendBtn.setAttribute('aria-busy', String(isLoading));
	}

	async function sendMessage(message) {
		let response;
		try {
			response = await fetch(apiUrl, {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({
					message,
					history: history.slice(-12)
				})
			});
		} catch {
			throw new Error('The assistant API is not reachable. Start the Worker or try again later.');
		}

		const payload = await response.json();

		if (!response.ok) {
			throw new Error(payload.error || 'The assistant could not answer right now.');
		}

		if (!payload.answer) {
			throw new Error('The assistant returned an empty answer.');
		}

		return payload.answer;
	}

	btn.addEventListener('click', openChat);
	close.addEventListener('click', closeChat);
	modal.addEventListener('click', event => {
		if (event.target === modal) closeChat();
	});
	form.addEventListener('submit', async event => {
		event.preventDefault();
		setError('');

		const message = input.value.trim();
		if (!message) return;
		if (!apiUrl) {
			setError('The assistant endpoint is not configured yet.');
			return;
		}

		input.value = '';
		appendMessage('user', message);
		history.push({ role: 'user', content: message });
		setLoading(true);

		try {
			const answer = await sendMessage(message);
			appendMessage('assistant', answer);
			history.push({ role: 'assistant', content: answer });
		} catch (error) {
			setError(error instanceof Error ? error.message : 'The assistant could not answer.');
		} finally {
			setLoading(false);
			input.focus();
		}
	});
</script>
