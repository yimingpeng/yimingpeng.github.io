<style>
	.hero {
		padding: 8rem 0 4rem;
	}

	.container {
		max-width: 1000px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}

	.hero-content {
		display: flex;
		align-items: center;
		gap: 4rem;
	}

	.hero-text {
		flex: 1;
	}

	h1 {
		font-family: 'JetBrains Mono', 'Fira Code', monospace;
		font-size: 2.2rem;
		font-weight: 600;
		color: #cdd6f4;
		line-height: 1.4;
		margin-bottom: 1.25rem;
	}

	.terminal-cursor {
		color: #a6e3a1;
	}

	.tagline {
		font-size: 1.2rem;
		color: #89b4fa;
		font-weight: 500;
		margin-bottom: 1rem;
		line-height: 1.5;
	}

	.bio {
		color: #bac2de;
		line-height: 1.7;
		font-size: 1rem;
		margin-bottom: 2rem;
	}

	.bio strong {
		color: #cdd6f4;
	}

	.social-links {
		display: flex;
		align-items: center;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.social-link {
		color: #6c7086;
		transition: color 0.2s ease;
		display: flex;
		align-items: center;
	}

	.social-link:hover {
		color: #a6e3a1;
	}

	.cv-link {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.35rem 0.85rem;
		border: 1px solid rgba(166, 227, 161, 0.4);
		border-radius: 6px;
		color: #a6e3a1;
		font-family: 'JetBrains Mono', 'Fira Code', monospace;
		font-size: 0.85rem;
		font-weight: 500;
		text-decoration: none;
		transition: all 0.2s ease;
	}

	.cv-link:hover {
		background: rgba(166, 227, 161, 0.1);
		border-color: #a6e3a1;
	}

	.hero-image {
		flex-shrink: 0;
	}

	.profile-img {
		width: 200px;
		height: 200px;
		border-radius: 50%;
		object-fit: cover;
		border: 2px solid rgba(166, 227, 161, 0.3);
		filter: grayscale(20%);
	}

	@media (max-width: 768px) {
		.hero {
			padding: 6rem 0 3rem;
		}

		.hero-content {
			flex-direction: column-reverse;
			gap: 2rem;
			text-align: center;
		}

		.social-links {
			justify-content: center;
		}

		h1 {
			font-size: 1.6rem;
		}

		.profile-img {
			width: 140px;
			height: 140px;
		}
	}

	@media (max-width: 480px) {
		h1 {
			font-size: 1.3rem;
		}

		.tagline {
			font-size: 1.05rem;
		}
	}
</style>
