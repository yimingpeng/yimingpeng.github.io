---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import '../styles/global.css';
import '../styles/header.css';
import '../styles/publications-page.css';
---

<BaseLayout
	title="Publications - Yiming Peng"
	description="Research publications by Yiming Peng in Machine Learning, Reinforcement Learning, and Evolutionary Computation"
>
	<Header />
	<main class="publications-page">
		<div class="container">
			<div class="page-header">
				<h1 class="page-title">$ cat publications.txt</h1>
				<p class="page-subtitle">
					Research publications in machine learning and evolutionary computation
				</p>
				<a href="/" class="back-link">← Back to home</a>
			</div>

			<div class="publications-placeholder">
				<div class="placeholder-content">
					<div class="placeholder-icon">📚</div>
					<h2 class="placeholder-title">Publications Coming Soon</h2>
					<div class="placeholder-text">
						<p>
							I'm currently updating my publication list with the latest research. Check back soon
							for a comprehensive overview of my work in machine learning and evolutionary
							computation.
						</p>
					</div>
					<div class="placeholder-note">
						<p>
							<em> Note: Publication details are being refined and will be available shortly. </em>
						</p>
					</div>
				</div>
			</div>
		</div>
	</main>
</BaseLayout>
