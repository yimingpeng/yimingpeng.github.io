---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import TerminalCLI from '../components/TerminalCLI.astro';
import AIChatPlaceholder from '../components/AIChatPlaceholder.astro';
import CommunityPreview from '../components/CommunityPreview.astro';
import {
	getSortedPublications,
	LINKEDIN_PUBLICATIONS_URL,
	SCHOLAR_URL,
	TOTAL_CITATIONS
} from '../data/publications';

const publications = getSortedPublications();
const peerReviewedPublications = publications.filter(publication =>
	['journal', 'conference'].includes(publication.type)
);
const peerReviewedCount = peerReviewedPublications.length;
const peerReviewedYears = peerReviewedPublications
	.map(publication => publication.year)
	.filter((y): y is number => y != null);
const peerReviewedYearSpan = `${Math.min(...peerReviewedYears)}-${Math.max(...peerReviewedYears)}`;
const CREDLY_PROFILE_URL = 'https://www.credly.com/users/yiming-peng.87fe02c4';
